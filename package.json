{
  "name": "actoviq-claw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A full-screen autonomous TUI assistant built on the local actoviq-agent-sdk.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@types/react": "^18.3.18",
    "actoviq-agent-sdk": "0.1.11",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "string-width": "^5.1.2",
    "wrap-ansi": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^4.0.8"
  }
}
